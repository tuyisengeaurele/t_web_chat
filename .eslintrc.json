{
    "env": {
          "browser": true,
          "es2022": true,
          "node": true
    },
    "extends": ["eslint:recommended"],
    "parserOptions": {
          "ecmaVersion": 2022,
          "sourceType": "module"
    },
    "rules": {
          "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
          "no-console": "off",
          "prefer-const": "error",
          "eqeqeq": ["error", "always"],
          "curly": "error",
          "no-var": "error"
    }
}
